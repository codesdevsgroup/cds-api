generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Configurações do Sistema
model Config {
  configId    Int     @id @default(autoincrement())
  nomeCliente String  @db.VarChar(80)
  email       String  @db.VarChar(80)
  celular     String  @db.VarChar(15)
  telefone1   String? @db.VarChar(15)
  telefone2   String? @db.VarChar(15)
  rua         String  @db.VarChar(100)
  numero      String  @db.VarChar(10)
  complemento String? @db.VarChar(50)
  bairro      String  @db.VarChar(80)
  cidade      String  @db.VarChar(80)
  estado      String  @db.Char(2)
  cep         String  @db.VarChar(10)

  @@map("config")
}

// Modelo de Usuário para Autenticação
model Usuarios {
  usuarioId       String    @id @default(cuid())
  email           String    @unique @db.VarChar(80)
  usuarioNome     String    @unique @db.VarChar(15)
  cpfCnpj         String?   @db.VarChar(14)
  password        String    @db.VarChar(255)
  dataCriacao     DateTime  @default(now())
  dataAtualizacao DateTime  @updatedAt
  deletado        Boolean   @default(false)
  dataDeletado    DateTime?
  activo          Boolean   @default(false)
  dataActivacao   DateTime?
  termosIp        String?   @db.VarChar(45)
  termosAceito    Boolean   @default(false)
  pessoaId        Int?      @unique
  tokenVersao     Int       @default(0)

  @@map("usuarios")
}
